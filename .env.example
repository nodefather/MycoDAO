# Copy to `.env.local` (dev) or `.env.production` (VM). Never commit real secrets.

# Cloudflare Tunnel (optional). Token from Zero Trust → Networks → Tunnels → your tunnel → token.
# Used by `docker compose --profile tunnel`. See docs/PULSE_CLOUDFLARE_TUNNEL_SETUP_APR14_2026.md
CLOUDFLARE_TUNNEL_TOKEN=



# Empty = app at domain root (e.g. https://pulse.mycodao.com/). Set only if serving under a subpath.

# Must match `next.config.mjs` / build-time embedding (e.g. `/mycodao.financial` for legacy subpath deploys).

NEXT_PUBLIC_BASE_PATH=



# Client: enable SSE ticker stream (`/api/pulse/stream`). Set `1` or `true` to connect from Pulse UI.

NEXT_PUBLIC_PULSE_SSE=



# Market data (server-only). Required for best OHLC + quotes; see https://finnhub.io

FINNHUB_API_KEY=



# Optional: MINDEX OHLC when `/api/ohlc` is implemented server-side

# On the dedicated MycoDAO guest (Proxmox 192.168.0.90), point at LAN APIs — no changes to those VMs:

# MINDEX_API_URL=http://192.168.0.189:8000

# MAS_API_URL=http://192.168.0.188:8001

MINDEX_API_URL=

MINDEX_INTERNAL_TOKEN=



MAS_API_URL=



# Optional: NatureOS — used by `npm run check:backends`

NATUREOS_API_URL=



# MYCO token price from DexScreener

MYCO_SOLANA_MINT=



# News (server-only). GNews is preferred when set; some adapters accept `NEWS_API_KEY` as alias.

GNEWS_API_KEY=

NEWS_API_KEY=



# Podcasts: comma-separated RSS feed URLs for `/api/podcasts`

PODCAST_RSS_URLS=



# Learn (`/pulse/learn`): optional HTTPS JSON array of LearnModule (same schema as `data/learn-modules.json`)

LEARN_MODULES_URL=



# Dev only: when unset remote/file missing or invalid, serve minimal fallback lessons (never enable in production)

LEARN_DEV_FALLBACK=



# --- Pulse Podcast studio (`/pulse/podcasts`) — live, stream deck, chat ---

# Default live iframe (YouTube Live embed, Cloudflare Stream, etc.)

# NEXT_PUBLIC_PULSE_PODCAST_LIVE_EMBED_URL=https://www.youtube.com/embed/LIVE_VIDEO_ID

# Label next to LIVE badge

# NEXT_PUBLIC_PULSE_PODCAST_LIVE_LABEL=MycoDAO Live

# Stream deck: JSON array of { "id", "label", "embedUrl" } — https embed URLs only; switches live iframe

# NEXT_PUBLIC_PULSE_STREAMDECK_JSON=[{"id":"main","label":"Program","embedUrl":"https://www.youtube.com/embed/..."}]

# Chat persists to `data/podcast-chat.json` (single-instance; gitignored)




# Calendar: optional JSON URL override (else Finnhub economic calendar when `FINNHUB_API_KEY` is set)

CALENDAR_JSON_URL=



# Pulse behavior (see lib/server/pulse-env.ts)

PULSE_TRADE_FAST_PATH=1



# --- Trading terminal (DEX/CEX via broker service; see lib/server/trading-env.ts) ---

# Base URL of your execution adapter (MAS, CCXT, Jupiter, etc.). Must implement:

#   POST /v1/orders  GET /v1/orders  GET /v1/positions  optional POST /v1/quote

TRADING_BROKER_BASE_URL=

# Outbound auth to the broker (optional)

TRADING_BROKER_TOKEN=



# Agents & scripts send this header to Pulse: Authorization: Bearer ... or X-Pulse-Trading-Key

PULSE_TRADING_API_KEY=



# LAN/VPN only: allow browser POST from same origin without the key (use with care)

PULSE_TRUST_SAME_ORIGIN_TRADING=



# Optional smoke script override (default: http://localhost:3004 + NEXT_PUBLIC_BASE_PATH)

# PULSE_SMOKE_BASE=http://localhost:3004



# --- Pulse → MAS task proxy (`POST /api/pulse/mas-task`) — server only; never expose secret to browser

# Shared secret: client of the route must send header `x-pulse-internal-key: <value>`

PULSE_MAS_PROXY_SECRET=



# Dev/LAN only: allow proxy without key (never set in public production)

PULSE_ALLOW_OPEN_MAS_PROXY=



# --- Optional Supabase (see supabase/migrations/001_mycodao_pulse_agent_runs.sql) ---

SUPABASE_URL=

SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=



# --- Pulse News terminal (`/pulse/news`) — client NEXT_PUBLIC_* ---

# iframe embed URL for live video (YouTube Live, Cloudflare Stream, Vimeo, etc.)

# NEXT_PUBLIC_PULSE_NEWS_VIDEO_EMBED_URL=https://www.youtube.com/embed/VIDEO_ID

# Optional label shown next to LIVE

# NEXT_PUBLIC_PULSE_NEWS_STREAM_LABEL=CNBC / Bloomberg stream

# Comma-separated symbols for the top tape (must exist in `/api/tickers` feed)

# NEXT_PUBLIC_PULSE_NEWS_TAPE_SYMBOLS=BTC,ETH,SPY,QQQ,MYCO,NVDA

# Sponsorship images (full URLs). Secondary is optional banner below primary.

# NEXT_PUBLIC_PULSE_NEWS_AD_IMAGE_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_SECONDARY_IMAGE_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_CLICK_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_TITLE=


